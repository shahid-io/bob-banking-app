# .env.example — Copy this file to .env and fill in real values.
# The .env file must NEVER be committed to version control.
#
# All variables are optional in development (defaults are used).
# In production every variable marked [REQUIRED] must be set.

# -----------------------------------------------------------------------
# Flask core
# -----------------------------------------------------------------------

# [REQUIRED in production] Long random string used to sign session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-replace-in-production

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------

# [REQUIRED in production] Absolute path to the SQLite database file.
# Example: DATABASE_URL=/var/app/banking.db
# Leave blank in development — the app defaults to BACKEND/banking.db
DATABASE_URL=

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL  (default: INFO)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------

# Which config class to use: development | testing | production  (default: development)
FLASK_ENV=development
